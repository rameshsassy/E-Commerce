VITE_API_URL=http://localhost:5000/api

# --- Vercel / production (required or login will fail) ---
# VITE_API_URL=https://YOUR-API.onrender.com/api
# Do not use localhost values on Vercel. Redeploy after changing.

# Customer portal (default dev)
VITE_CUSTOMER_PORTAL_URL=http://localhost:5173

# Seller portal — use seller.localhost in /etc/hosts, or VITE_PORTAL=seller
VITE_SELLER_PORTAL_URL=http://seller.localhost:5173
# Local seller host only until seller.aashansh.org DNS is ready
VITE_SELLER_PORTAL_HOSTS=seller.localhost

# Force portal when both run on localhost:5173 (normally use separate hostnames)
# VITE_PORTAL=customer
# VITE_PORTAL=seller

# WhatsApp support (approved product edits) — digits with country code, no +
# VITE_SUPPORT_WHATSAPP_NUMBER=919876543210
