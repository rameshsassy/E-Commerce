# Local development only
VITE_API_URL=http://localhost:5000/api

# Customer portal (default dev)
VITE_CUSTOMER_PORTAL_URL=http://localhost:5173

# Seller portal — use seller.localhost in /etc/hosts, or VITE_PORTAL=seller
VITE_SELLER_PORTAL_URL=http://seller.localhost:5173
VITE_SELLER_PORTAL_HOSTS=seller.localhost

# --- Vercel (Project → Settings → Environment Variables) ---
# REQUIRED for login to work on Vercel (then Redeploy — build writes vercel.json proxy):
# BACKEND_URL=https://your-api.onrender.com
# Test after deploy: https://e-commerce-snj1.vercel.app/api/health → {"ok":true}
# Deploy API: push repo to GitHub → Render.com → New Web Service → use render.yaml
# Or set the full API path:
# VITE_API_URL=https://your-api.onrender.com/api
#
# On the API server (.env on Render/Railway):
# FRONTEND_URL=https://e-commerce-snj1.vercel.app
# CORS_ALLOW_VERCEL=true
#
# After changing env vars, redeploy the frontend on Vercel.
