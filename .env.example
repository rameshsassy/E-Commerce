# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration
# Local: mongodb://127.0.0.1:27017/aashansh
# Atlas: mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/aashansh?retryWrites=true&w=majority
# If the password contains @ # : / etc., URL-encode it (e.g. @ → %40) or the host will parse wrong.
MONGO_URI=mongodb://localhost:27017/aashansh

# Authentication
JWT_SECRET=your_jwt_secret_key_here
ADMIN_SECRET_KEY=your_admin_secret_key_here

# Razorpay (seller Premium subscription — Orders API)
# Dashboard: https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=rzp_test_xxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxx
# Optional: override price in paise (default 1076750 = ₹10,767.50 incl. 18% GST on ₹9,125)
# PREMIUM_SUBSCRIPTION_AMOUNT_PAISE=1076750

# SMTP Email Configuration (Placeholders)
# If mail fails with ENETUNREACH to an IPv6 address, default 4 pre-resolves the SMTP host to IPv4 (dns.lookup).
# Use auto to pass the hostname through unchanged, or 6 for IPv6-only resolution.
# SMTP_CONNECTION_FAMILY=4

# 1. Seller Care (for signup, login, etc.)
SMTP_SELLER_HOST=smtp.gmail.com
SMTP_SELLER_PORT=587
SMTP_SELLER_USER=seller.care@aashansh.org
SMTP_SELLER_PASS=your_seller_app_password
SMTP_SELLER_FROM=seller.care@aashansh.org

# 2. Customer Care (for support, welcome, etc.)
SMTP_CUSTOMER_HOST=smtp.gmail.com
SMTP_CUSTOMER_PORT=587
SMTP_CUSTOMER_USER=customer.care@aashansh.org
SMTP_CUSTOMER_PASS=your_customer_app_password
SMTP_CUSTOMER_FROM=customer.care@aashansh.org

# 3. Orders (for order updates, invoices, etc.)
SMTP_ORDER_HOST=smtp.gmail.com
SMTP_ORDER_PORT=587
SMTP_ORDER_USER=order@aashansh.org
SMTP_ORDER_PASS=your_order_app_password
SMTP_ORDER_FROM=order@aashansh.org

PLATFORM_BULK_ADMIN_EMAIL=admin@aashansh.org

# Frontend Configuration (required for browser CORS when using cookies / credentials)
# Use the exact origin(s) of your deployed SPA — no trailing slash. Multiple: comma-separated.
# Example: https://my-shop.vercel.app,https://www.myshop.com
# Customer marketplace (aashansh.org)
FRONTEND_URL=http://localhost:5174
# Seller portal (seller.aashansh.org) — comma-separated origins for CORS
SELLER_FRONTEND_URL=http://seller.localhost:5175
# Optional extra seller hostnames (without protocol)
# SELLER_PORTAL_HOSTS=seller.aashansh.org,seller.localhost
# CUSTOMER_PORTAL_HOST=aashansh.org

# WhatsApp for approved-product edit requests (digits only, country code included)
# SUPPORT_WHATSAPP_NUMBER=919876543210
# Seller payout calculation (used in seller shipments/orders)
SELLER_PLATFORM_FEE_PERCENT=12.39
# Host shown in seller subdomain previews (default: hostname from FRONTEND_URL)
# STORE_PLATFORM_HOST=aashansh.org
# Optional: extra allowed origins (comma-separated)
# CORS_EXTRA_ORIGINS=https://preview-abc123.vercel.app
# On Vercel: allow any https://*.vercel.app frontend (convenient for preview URLs)
# CORS_ALLOW_VERCEL=true
#
# Vercel frontend project — set in Vercel dashboard (not in this backend .env):
# BACKEND_URL=https://your-api.onrender.com
# (Build proxies /api to that host; see ecommerce_frontend/frontend/.env.example)
# Allow file:// pages (Origin: null) — dev / testing only
# ALLOW_CORS_NULL_ORIGIN=true

# File Upload Configuration
MAX_FILE_SIZE=5242880
# All uploaded images are compressed to JPEG at or below this size (bytes). Default: 102400 (100 KB)
# MAX_IMAGE_BYTES=102400
# Or use kilobytes: MAX_IMAGE_KB=100
# Optional: absolute directory for uploads (local default: ./uploads; Vercel/Lambda: /tmp/uploads)
# UPLOAD_DIR=/var/data/uploads

# Google Drive Storage Configuration (for product images)
# GOOGLE_DRIVE_CLIENT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
# GOOGLE_DRIVE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"
# GOOGLE_DRIVE_FOLDER_ID=your_google_drive_shared_folder_id
