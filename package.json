{
  "name": "backend_e-commerce",
  "version": "1.0.0",
  "type": "module",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node scripts/free-port.js && nodemon server.js",
    "dev:stop": "pkill -f 'nodemon server.js' 2>/dev/null; node scripts/free-port.js || true",
    "build:web": "npm run build:customer && npm run build:seller && npm run build:admin",
    "build:customer": "cd ecommerce_frontend/customer && npm run build",
    "build:seller": "cd ecommerce_frontend/seller && npm run build",
    "build:admin": "cd ecommerce_frontend/admin && npm run build",
    "seed": "node scripts/seed-db.js"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "country-state-city": "^3.2.1",
    "csv-parser": "^3.2.0",
    "dotenv": "^16.6.1",
    "exceljs": "^4.4.0",
    "express": "^4.18.2",
    "googleapis": "^173.0.0",
    "jsonwebtoken": "^9.0.0",
    "mongoose": "^8.0.0",
    "multer": "^2.1.1",
    "node-cron": "^3.0.3",
    "nodemailer": "^8.0.7",
    "razorpay": "^2.9.6",
    "sanitize-html": "^2.17.3",
    "serverless-http": "^3.2.0",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "nodemon": "^3.0.0"
  }
}
